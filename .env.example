# Environment Variables for Predict26
# Copy this file to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL (used for OAuth redirects)
# Production: NEXT_PUBLIC_SITE_URL=https://predict26.live
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-side post-match sync
# OPENAI_API_KEY enables the OpenAI Responses API web_search provider.
OPENAI_API_KEY=your-openai-api-key
# CRON_SECRET protects scheduled/admin sync endpoint calls.
CRON_SECRET=your-cron-secret
